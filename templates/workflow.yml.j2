# GitHub Actions workflow generated by Vaibify.
# Template: workflow.yml.j2
#
# This workflow builds the project's Docker image, runs the pipeline
# inside the container, and uploads any artifacts produced.

name: Vaibify Reproducibility

on:
  push:
    branches: [{{ sBranch | default("main") }}]
  pull_request:
    branches: [{{ sBranch | default("main") }}]
  workflow_dispatch:

jobs:
  reproduce:
    runs-on: {{ sRunner | default("ubuntu-latest") }}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "{{ sPythonVersion | default('3.12') }}"

      - name: Install Vaibify
        run: pip install vaibify

      - name: Build container image
        run: vaibify build

      - name: Run pipeline
        run: vaibify start --run-pipeline
{% if bUploadArtifacts %}

      - name: Upload artifacts
        uses: actions/upload-artifact@v4
        with:
          name: pipeline-outputs
          path: {{ sArtifactsPath | default("outputs/") }}
{% endif %}
