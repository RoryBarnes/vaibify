# Vaibify — Claude Code overlay
#
# Adds Claude Code via Anthropic's native installer. The installer
# fetches a self-contained binary into the container user's home
# (~/.local/share/claude/versions/<ver>) and a launcher symlink at
# ~/.local/bin/claude. No Node.js, no npm, no root, no prefix
# gotchas — the install is owned by the container user end-to-end
# and self-updates without sudo.

ARG BASE_IMAGE=vaibify:latest
FROM ${BASE_IMAGE}

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Run as the container user so the install lands in their home and
# is owned by them — a prerequisite for in-container auto-update.
USER ${CONTAINER_USER}

# Download the native installer over HTTPS, then run it. Splitting
# download from execution lets us emit an actionable diagnostic when
# the network call fails — same template as the deadsnakes block in
# docker/Dockerfile.
RUN if ! curl -fsSL --retry 3 --retry-connrefused --retry-delay 5 \
            --connect-timeout 30 \
            https://claude.ai/install.sh \
            -o /tmp/claude-install.sh; then \
        echo "" >&2; \
        printf '%s\n' "vaibify build (claude overlay): cannot download Claude Code installer." >&2; \
        printf '%s\n' "  - The installer lives at claude.ai/install.sh." >&2; \
        printf '%s\n' "  - Download failed (likely a TLS or network failure between" >&2; \
        printf '%s\n' "    this build host and claude.ai)." >&2; \
        printf '%s\n' "Pick one workaround:" >&2; \
        printf '%s\n' "  1. Disable the Claude overlay (features: { claude: false })." >&2; \
        printf '%s\n' "  2. Resolve your build host's network path to" >&2; \
        printf '%s\n' "     claude.ai (proxy, IPv6, MTU, TLS inspection)" >&2; \
        printf '%s\n' "     and rebuild." >&2; \
        echo "" >&2; \
        exit 1; \
    fi \
    && if ! bash /tmp/claude-install.sh; then \
        echo "" >&2; \
        printf '%s\n' "vaibify build (claude overlay): Claude Code installer failed." >&2; \
        printf '%s\n' "  - The installer downloaded successfully but exited non-zero." >&2; \
        printf '%s\n' "  - Binary downloads live at downloads.claude.ai." >&2; \
        printf '%s\n' "Pick one workaround:" >&2; \
        printf '%s\n' "  1. Disable the Claude overlay (features: { claude: false })." >&2; \
        printf '%s\n' "  2. Resolve your build host's network path to" >&2; \
        printf '%s\n' "     downloads.claude.ai (proxy, IPv6, MTU, TLS inspection)" >&2; \
        printf '%s\n' "     and rebuild." >&2; \
        echo "" >&2; \
        exit 1; \
    fi \
    && rm -f /tmp/claude-install.sh

# Ensure the installer's launcher directory is on PATH for any shell
# context (login or not). The installer adds it for login shells via
# the user's profile, but non-login subprocesses won't see it without
# this explicit ENV.
ENV PATH="/home/${CONTAINER_USER}/.local/bin:${PATH}"

# vaibify-do lives under /usr/local/bin so the container user can
# invoke it without a home-dir lookup. Briefly switch to root for
# the copy, then restore the unprivileged user from the base image.
USER root
COPY vaibifyDo.py /usr/local/bin/vaibify-do
RUN chmod 0755 /usr/local/bin/vaibify-do

USER ${CONTAINER_USER}
